# ═══════════════════════════════════════════════════════
# CareerOS — Environment Configuration
# ═══════════════════════════════════════════════════════
# 首次使用：
#   cp web/.env.example web/.env
# 然后填入下面标 [必填] 的值。
#
# 所有值也可以在 Streamlit UI「系统设置」页面里填（会覆盖本文件）。


# ── Anthropic Claude API [必填] ──────────────────────────
# 去 https://console.anthropic.com/ 申请，有 $5 免费额度
ANTHROPIC_API_KEY=sk-ant-your-key-here

# 自定义 API 代理地址（国内用户可选；留空走官方）
# 例：https://your-proxy.com
ANTHROPIC_BASE_URL=

# 使用的模型。推荐：
#   claude-opus-4-6     - 质量最好，最贵
#   claude-sonnet-4-6   - 性价比高（默认）
#   claude-haiku-4-5    - 最快最便宜，定制简历够用
CLAUDE_MODEL=claude-sonnet-4-6


# ── Email SMTP [可选] ────────────────────────────────────
# 配了才能从系统直接发投递邮件；不配就只能"复制到剪贴板"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password

# Gmail 用户：要在 Google 账户 → 安全 → 两步验证 → 应用专用密码 里生成
# QQ 邮箱：SMTP_HOST=smtp.qq.com，SMTP_USER 是你的 QQ 邮箱


# ── SendGrid（SMTP 替代方案 · 可选）───────────────────────
# SENDGRID_API_KEY=SG.your-key-here


# ── 路径配置（默认值适用大多数场景）─────────────────────
DB_PATH=../data/career_os.db
MASTER_RESUME_PATH=data/master_resume.yaml
OUTPUT_DIR=output/


# ── Demo 模式（公网部署时建议开启）──────────────────────
# true = BYO-Key 模式：强制用户自己填 Key，禁用真实邮件发送
# false = 本地私用（完全功能）
DEMO_MODE=false
